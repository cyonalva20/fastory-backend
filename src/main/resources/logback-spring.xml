<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- ══════════════════════════════════════════════
         Logback config para Fastory Backend
         Envía logs estructurados a Grafana Loki
         ══════════════════════════════════════════════ -->

    <!-- Console appender (para CloudWatch y desarrollo local) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Loki appender: push logs directo a Grafana Loki -->
    <springProfile name="!test">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>${LOKI_URL:-http://localhost:3100/loki/api/v1/push}</url>
            </http>
            <format>
                <label>
                    <pattern>app=fastory-backend,host=${HOSTNAME},level=%level,job=%mdc{job:-api},endpoint=%mdc{endpoint:-none},method=%mdc{method:-none},status=%mdc{status:-0},user=%mdc{user:-anonymous},action=%mdc{action:-none},ip=%mdc{ip:-unknown}</pattern>
                </label>
                <message>
                    <pattern>[%level] %d{yyyy-MM-dd HH:mm:ss} - %mdc{method} %mdc{endpoint} - status: %mdc{status} - time: %mdc{duration}ms%n%msg</pattern>
                </message>
                <sortByTime>true</sortByTime>
            </format>
        </appender>
    </springProfile>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- Solo activar Loki en perfiles no-test -->
    <springProfile name="!test">
        <root level="INFO">
            <appender-ref ref="LOKI" />
        </root>
    </springProfile>

    <!-- Silenciar loggers ruidosos -->
    <logger name="org.hibernate.SQL" level="WARN" />
    <logger name="org.springframework.security" level="INFO" />
</configuration>
