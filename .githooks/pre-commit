#!/bin/bash
# ──────────────────────────────────────────────
# Git Hook: Pre-Commit — Fastory Backend
# ──────────────────────────────────────────────
# Se ejecuta automáticamente antes de cada commit.
# Valida la compilación y ejecuta los tests unitarios.
# Si alguno falla, el commit se bloquea.
# ──────────────────────────────────────────────
# Activar: git config core.hooksPath .githooks
# ──────────────────────────────────────────────

set -e

echo "╔══════════════════════════════════════════╗"
echo "║   🔍 PRE-COMMIT HOOK — Fastory Backend  ║"
echo "╚══════════════════════════════════════════╝"

# ── 1. Verificar compilación ──
echo ""
echo "📦 [1/2] Verificando compilación..."
mvn compile -q -DskipTests 2>/dev/null
if [ $? -ne 0 ]; then
    echo "❌ ERROR: La compilación falló. Commit bloqueado."
    exit 1
fi
echo "✅ Compilación exitosa."

# ── 2. Ejecutar tests unitarios ──
echo ""
echo "🧪 [2/2] Ejecutando tests unitarios..."
mvn test -q 2>/dev/null
if [ $? -ne 0 ]; then
    echo "❌ ERROR: Los tests fallaron. Commit bloqueado."
    echo "   Ejecuta 'mvn test' para ver los detalles."
    exit 1
fi
echo "✅ Todos los tests pasaron."

echo ""
echo "════════════════════════════════════════════"
echo "  ✅ Pre-commit exitoso. Procediendo..."
echo "════════════════════════════════════════════"
