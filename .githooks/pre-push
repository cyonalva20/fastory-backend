#!/bin/bash
# ──────────────────────────────────────────────
# Git Hook: Pre-Push — Fastory Backend
# ──────────────────────────────────────────────
# Se ejecuta automáticamente antes de cada push.
# Realiza una verificación completa del proyecto
# (compilación + tests + empaquetado) para asegurar
# que el código que llega a GitHub es estable.
# ──────────────────────────────────────────────
# Activar: git config core.hooksPath .githooks
# ──────────────────────────────────────────────

set -e

echo "╔══════════════════════════════════════════╗"
echo "║   🚀 PRE-PUSH HOOK — Fastory Backend    ║"
echo "╚══════════════════════════════════════════╝"

# ── 1. Verificación completa con Maven ──
echo ""
echo "🔎 Ejecutando verificación completa (mvn verify)..."
echo "   Esto incluye: compilación + tests + empaquetado"
echo ""
mvn verify -q 2>/dev/null
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ ERROR: La verificación falló. Push bloqueado."
    echo "   Ejecuta 'mvn verify' para ver los detalles."
    exit 1
fi

echo ""
echo "════════════════════════════════════════════"
echo "  ✅ Pre-push exitoso. Subiendo código..."
echo "════════════════════════════════════════════"
